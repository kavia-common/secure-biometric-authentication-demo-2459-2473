<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Material Design 3-style palette.
      This is intentionally simple (not generated by Material Theme Builder) but provides:
      - brand primary = #3B82F6
      - accent/tertiary = #06B6D4
      - modern neutral surfaces
    -->

    <!-- Brand / primary -->
    <color name="md_theme_primary">#3B82F6</color>
    <color name="md_theme_onPrimary">#FFFFFF</color>
    <color name="md_theme_primaryContainer">#DBEAFE</color>
    <color name="md_theme_onPrimaryContainer">#0B1220</color>

    <!-- Secondary (neutral, used for subtle emphasis) -->
    <color name="md_theme_secondary">#64748B</color>
    <color name="md_theme_onSecondary">#FFFFFF</color>
    <color name="md_theme_secondaryContainer">#E2E8F0</color>
    <color name="md_theme_onSecondaryContainer">#0F172A</color>

    <!-- Tertiary (accent/success) -->
    <color name="md_theme_tertiary">#06B6D4</color>
    <color name="md_theme_onTertiary">#001316</color>

    <!-- Surfaces -->
    <color name="md_theme_background">#F9FAFB</color>
    <color name="md_theme_onBackground">#111827</color>
    <color name="md_theme_surface">#FFFFFF</color>
    <color name="md_theme_onSurface">#111827</color>

    <!-- Error -->
    <color name="md_theme_error">#EF4444</color>
    <color name="md_theme_onError">#FFFFFF</color>

    <!-- Kept for launcher adaptive icon background reference -->
    <color name="ic_launcher_background">#F9FAFB</color>
</resources>
